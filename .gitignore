# /data/ (repo root) is generated at build time and checked in, so GitHub
# Pages can serve it directly without depending on the Actions workflow being
# green. Regenerated by `npm run build`.
# pages/hsk/data/ contains large reference corpora (CEDICT, etc.) — excluded.
pages/hsk/data/
