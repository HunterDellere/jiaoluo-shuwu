{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "entry.schema.json",
  "title": "Jiǎoluò Shūwū Content Entry",
  "description": "Frontmatter schema for all content files in content/",
  "type": "object",
  "required": ["type", "category", "title", "desc", "status"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["character", "vocab", "grammar", "topic", "hub"]
    },
    "category": {
      "type": "string",
      "enum": ["characters", "vocab", "grammar", "chengyu", "religion", "philosophy", "history", "geography", "culture", "culinary", "arts", "science", "daily", "hsk", "hubs"]
    },
    "status": {
      "type": "string",
      "enum": ["complete", "stub", "draft"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "desc": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Required when status is complete"
    },
    "char": {
      "type": "string",
      "description": "character entries only — the single hanzi"
    },
    "pinyin": {
      "type": "string",
      "description": "Tone-marked pinyin"
    },
    "tone": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Tone number 1–4 (5 = neutral)"
    },
    "hsk": {
      "oneOf": [
        { "type": "integer", "minimum": 1, "maximum": 9 },
        {
          "type": "object",
          "required": ["from", "to"],
          "properties": {
            "from": { "type": "integer", "minimum": 1, "maximum": 9 },
            "to":   { "type": "integer", "minimum": 1, "maximum": 9 }
          },
          "additionalProperties": false
        }
      ],
      "description": "HSK level (integer) or range (object with from/to)"
    },
    "radical": {
      "type": "string",
      "description": "character entries only — the radical hanzi"
    },
    "trad": {
      "type": "string",
      "description": "Traditional form of the character; omit if identical to simplified"
    },
    "metaDesc": {
      "type": "string",
      "description": "SEO meta description override; falls back to desc if absent"
    },
    "pageTitle": {
      "type": "string",
      "description": "HTML <title> content (before ' — Jiǎoluò Shūwū · 角落書屋'); auto-generated if absent"
    },
    "topic": {
      "type": "string",
      "description": "Optional thematic grouping label (deprecated — use tags instead)"
    },
    "sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Optional list of sources cited; rendered as a small footer block on the page"
    },
    "related": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Optional explicit related entry slugs (e.g. 'characters/gan3_感') that are merged at the front of the auto-computed related list"
    },
    "stages": {
      "type": "array",
      "description": "Hub pages only — ordered reading stages, each with member entries.",
      "items": {
        "type": "object",
        "required": ["name", "color", "members"],
        "properties": {
          "name": { "type": "string" },
          "name_en": { "type": "string" },
          "cn": { "type": "string" },
          "color": { "type": "string", "enum": ["teal", "ochre", "sienna", "violet", "red"] },
          "note": { "type": "string" },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slug", "label_cn"],
              "properties": {
                "slug":     { "type": "string" },
                "label_cn": { "type": "string" },
                "label_en": { "type": "string" },
                "type":     { "type": "string", "enum": ["Character", "Vocab", "Topic", "Grammar"] },
                "mins":     { "type": "integer", "minimum": 1 },
                "note":     { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "if": {
    "properties": { "status": { "const": "complete" } }
  },
  "then": {
    "required": ["updated"]
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "character" } } },
      "then": {
        "required": ["char", "pinyin", "tone", "hsk", "radical"]
      }
    }
  ],
  "additionalProperties": false
}
